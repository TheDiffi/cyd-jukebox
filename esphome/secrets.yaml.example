# SSID is the "Name" of the Wifi
wifi_ssid: "Your WiFi SSID"
wifi_password: "your_wifi_password"

# Home Assistant will ask you to enter this key once you add it as a device
# See https://esphome.io/components/api/ for more information
api_key: "your_esphome_api_key"

# The device creates a AP if if cannot connect to HA. This will be the password to enter that AP
ota_password: "your_ota_password"

# Home Assistant long-lived access token.
# HA → Profile → Security → Long-lived access tokens → Create token
# Store the full value including "Bearer ":
ha_token: "Bearer your_long_lived_access_token"
