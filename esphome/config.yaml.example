substitutions:
  # ── Configuration ─────────────────────────────────────────────────────────
  # Your Home Assistant media player entity ID (the Music Assistant player).
  # Find it in HA → Settings → Devices & Services → Entities.
  media_player_entity: media_player.your_player

  # Your Home Assistant base URL. Default port is 8123.
  # If you are unsure, just open up homeassistant in a browser and copy it from there.
  ha_url: "http://homeassistant.local:8123"

  # Device name used for ESPHome and HA discovery.
  device_name: cyd-jukebox
  friendly_name: "CYD Jukebox"

  # Quickplay Buttons
  # Follow the instructions in the cyd-playlists-page.yaml to get a playlist ID and set it here
  quickplay_button_chill_playlist_id: "library://playlist/15"
  quickplay_button_pop_playlist_name_id: "library://playlist/16"
  # ──────────────────────────────────────────────────────────────────────────
